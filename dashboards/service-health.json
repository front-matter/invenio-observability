    {
      "id": 14,
      "type": "gauge",
      "title": "Web Errors",
      "description": "Error log entries for the web service in the selected time range",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "victoriametrics-logs-datasource",
        "uid": "victorialogs"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.001 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "mappings": [],
          "decimals": 1,
          "unit": "percentunit",
          "noValue": "0",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "victorialogs"
          },
          "editorMode": "code",
          "expr": "container:inveniordm-* | stats count() if (log_level:error) as errors, count() as total | math (errors / total) default 0 as error_ratio | fields error_ratio",
          "queryType": "stats",
          "refId": "A"
        }
      ],
      "transformations": [],
      "options": {
        "reduceOptions": {
          "calcs": ["last"],
          "fields": "/^error_ratio$/",
          "values": false
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "minVizHeight": 75,
        "minVizWidth": 75
      }
    },
